# Treadwell Customer Proposal Portal — environment (prod values live in /opt/treadwell-portal/.env)

ENVIRONMENT=production

# Same Postgres the proposal tool uses (one source of truth).
# Prod: the Supabase Postgres connection string. Local dev uses docker-compose.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Public URL of this portal (used in emailed links).
PUBLIC_BASE_URL=https://portal.wetreadwell.com

# Shared secret the admin proposal tool sends as X-Service-Token to POST /api/notify.
SERVICE_TOKEN=

# Customer session / OTP
PORTAL_SESSION_TTL_HOURS=24
PORTAL_OTP_TTL_MINUTES=10
PORTAL_OTP_MAX_ATTEMPTS=5

# Email (Resend). With no key, emails are logged (dev). Sender must be a verified domain.
RESEND_API_KEY=
EMAIL_FROM=Treadwell <noreply@wetreadwell.com>
NOTIFY_EMAILS=kyle@wetreadwell.com,dane@wetreadwell.com,rj@wetreadwell.com,bids@wetreadwell.com
DEPOSIT_NOTIFY_EMAILS=kyle@wetreadwell.com,dane@wetreadwell.com,rj@wetreadwell.com,kyleene@wetreadwell.com,bids@wetreadwell.com

# Google Sign-In for customers (optional). A Google OAuth *Web Client ID* (public).
# Authorized JS origins must include the portal origins; OAuth consent screen must be
# "External" so customers' Google accounts work. Button only shows when this is set.
GOOGLE_CLIENT_ID=

# Dropbox (folder creation on approval). Leave blank to disable gracefully.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT_FOLDER=/Proposals

# Never set DEV_SEED=true in prod.
DEV_SEED=false
